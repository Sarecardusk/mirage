{
  "name": "mirage",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "pnpm typecheck && vite build",
    "check": "pnpm check:rust && pnpm check:web",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "check:web": "pnpm fmt:web:check && pnpm lint:web && pnpm typecheck",
    "dev": "vite",
    "fmt": "pnpm fmt:rust && pnpm fmt:web",
    "fmt:check": "pnpm fmt:rust:check && pnpm fmt:web:check",
    "fmt:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "fmt:rust:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check",
    "fmt:web": "prettier --write .",
    "fmt:web:check": "prettier --check .",
    "lint": "pnpm lint:rust && pnpm lint:web",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "lint:web": "eslint . --max-warnings=0",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "pnpm test:rust && pnpm test:web",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:web": "pnpm test:web:unit",
    "test:web:unit": "vitest run",
    "test:web:unit:watch": "vitest",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.3",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.13",
    "vue-router": "^5.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "debug": "^4.4.3",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.0.3",
    "vitest": "^4.1.0",
    "vue-tsc": "^2.1.10"
  }
}
